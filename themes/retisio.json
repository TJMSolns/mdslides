{
  "name": "Retisio",
  "version": "1.0.0",
  "background": {
    "color": "#FFFFFF"
  },
  "templateBackgrounds": {
    "content": "doc/internal/reference/tmp/retisio-content-page.png",
    "diagram": "doc/internal/reference/tmp/retisio-diagram-page.png",
    "closing": "doc/internal/reference/tmp/retisio-end-page.png",
    "section-title": "doc/internal/reference/tmp/retisio-section-title-page.png",
    "title": "doc/internal/reference/tmp/retisio-title-page.png"
  },
  "colors": {
    "text": "#002C74",
    "heading": "#002C74",
    "accent": "#FCC010",
    "link": "#0B9655",
    "linkHover": "#0B9655",
    "codeBackground": "#F5F5F5",
    "codeText": "#002C74"
  },
  "fonts": {
    "body": "'Varela Round', Arial, 'Helvetica Neue', Helvetica, sans-serif",
